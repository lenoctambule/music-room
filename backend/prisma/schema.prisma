generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  name          String
  googleId      String?   @unique
  emailVerified Boolean   @default(false)
  isAdmin       Boolean   @default(false)

  // Champs de profil avec niveaux de visibilité
  publicInfo       String?
  friendsInfo      String?
  privateInfo      String?
  musicPreferences String[]

  verificationCode       String?
  verificationCodeExpiry DateTime?
  resetToken             String?
  resetTokenExpiry       DateTime?

  // Relations amitié
  sentRequests     Friendship[] @relation("SentRequests")
  receivedRequests Friendship[] @relation("ReceivedRequests")

  // Relations événements
  createdEvents Event[]       @relation("CreatedEvents")
  eventMembers  EventMember[]
  tracks        Track[]
  votes         Vote[]

  // Relations playlists
  createdPlaylists Playlist[]       @relation("CreatedPlaylists")
  playlistMembers  PlaylistMember[]
  playlistTracks   PlaylistTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Friendship {
  id       String @id @default(uuid())
  userId   String
  friendId String
  status   String @default("PENDING") // PENDING | ACCEPTED

  user   User @relation("SentRequests", fields: [userId], references: [id])
  friend User @relation("ReceivedRequests", fields: [friendId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

enum LicenseType {
  OPEN
  INVITE_ONLY
  LOCATION_TIME
}

enum MemberRole {
  CREATOR
  INVITED
  PARTICIPANT
}

model Event {
  id          String      @id @default(uuid())
  name        String
  description String?
  creatorId   String
  isPublic    Boolean     @default(true)
  licenseType LicenseType @default(OPEN)
  startTime   DateTime?
  endTime     DateTime?
  latitude    Float?
  longitude   Float?

  creator User          @relation("CreatedEvents", fields: [creatorId], references: [id])
  members EventMember[]
  tracks  Track[]

  createdAt DateTime @default(now())
}

model Track {
  id          String  @id @default(uuid())
  eventId     String
  title       String
  artist      String
  externalUrl String?
  addedById   String
  voteCount   Int     @default(0)

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  addedBy User   @relation(fields: [addedById], references: [id])
  votes   Vote[]

  createdAt DateTime @default(now())
}

model Vote {
  id      String @id @default(uuid())
  trackId String
  userId  String

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([trackId, userId])
}

model EventMember {
  id      String     @id @default(uuid())
  eventId String
  userId  String
  role    MemberRole @default(PARTICIPANT)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([eventId, userId])
}

enum PlaylistLicense {
  OPEN
  INVITE_ONLY
}

model Playlist {
  id          String          @id @default(uuid())
  name        String
  description String?
  creatorId   String
  isPublic    Boolean         @default(true)
  licenseType PlaylistLicense @default(OPEN)

  creator User             @relation("CreatedPlaylists", fields: [creatorId], references: [id])
  members PlaylistMember[]
  tracks  PlaylistTrack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlaylistTrack {
  id          String  @id @default(uuid())
  playlistId  String
  title       String
  artist      String
  externalUrl String?
  addedById   String
  position    Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  addedBy  User     @relation(fields: [addedById], references: [id])

  createdAt DateTime @default(now())
}

model PlaylistMember {
  id         String  @id @default(uuid())
  playlistId String
  userId     String
  canEdit    Boolean @default(true)
  status     String  @default("ACCEPTED") // INVITED | ACCEPTED

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([playlistId, userId])
}
